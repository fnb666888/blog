{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "echo \"$CLAUDE_FILE_PATH\" | grep -qE '\\.(md|yaml|yml|json|scss|html|js)$' && npx prettier --write \"$CLAUDE_FILE_PATH\" || true"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": ["Read", "Edit", "Write", "Bash(hugo:*)", "Bash(npm:*)", "Bash(npx:*)", "Bash(date:*)", "Bash(find:*)", "Bash(du:*)", "Bash(ls:*)", "Bash(cat:*)", "Bash(head:*)", "Bash(tail:*)", "Bash(grep:*)", "Bash(mkdir:*)", "Bash(cp:*)", "Bash(mv:*)"],
    "deny": ["Bash(rm:*)", "Bash(rmdir:*)", "Bash(del:*)", "Bash(rd:*)"]
  }
}
